---
layout: 'base.njk'
---

<article class="post">
    <div class="cover">
        <img src="{{ image }}" alt="{{ imageAlt }}">
    </div>
    <h1>{{ title }}</h1>
    <p class="author-meta">by <span>{{ author }}</span> · <span>{{ date | postDate }}</span></p>
    <br>
    <br>
    <div class="post-body">
        {{ content | safe }}
    </div>
</article>